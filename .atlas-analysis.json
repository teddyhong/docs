  "keyFeatures": [
    "Online student enrollment with digital registration forms",
    "Automated invoice generation and payment reminders",
    "Real-time payment verification via payment gateway",
    "Daily activity sharing with photos and videos",
    "Child development milestone tracking and reporting",
    "Lesson plan creation and curriculum customization",
    "QR code-based student attendance",
    "Parent mobile app for real-time child monitoring",
    "Multi-branch management from a single account",
    "Family access sharing (Invite Family feature)"
  ],
  "publicApiSurface": [
    "Student enrollment form submission",
    "Invoice creation and management",
    "Recurring billing configuration",
    "Activity post (photo/video/note sharing)",
    "Attendance recording (manual and QR scan)",
    "Milestone and lesson plan management",
    "Daily activity report generation",
    "Parent and family account invitations",
    "Multi-organization (branch) switching"
