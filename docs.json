{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Fleedu",
  "description": "Dokumentasi Fleedu, software dan aplikasi untuk mengelola preschool / daycare. Temukan panduan lengkap untuk membantu staf, guru, dan orang tua menghemat waktu dalam mengatur kegiatan operasional serta pembelajaran anak usia dini.",
  "colors": {
    "primary": "#6b3dec",
    "light": "#b490e0",
    "dark": "#6b3dec"
  },
  "favicon": {
    "light": "/images/android-chrome-512x512.png",
    "dark": "/images/android-chrome-512x512.png"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "section"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "directory": "card",
    "products": [
      {
        "product": "What's New",
        "pages": [
          "index",
          "whats-new"
        ]
      },
      {
        "product": "Untitled Product",
        "tabs": [
          {
            "tab": "Guide",
            "hidden": true,
            "groups": [
              {
                "group": "Getting Started",
                "hidden": true,
                "pages": [
                  "introduction",
                  "getting-started/register",
                  "getting-started/setup-school"
                ]
              },
              {
                "group": "Administration",
                "hidden": true,
                "pages": [
                  "administration/student-enrollment",
                  "administration/class-management",
                  "administration/staff-roles"
                ]
              },
              {
                "group": "Billing & Payments",
                "hidden": true,
                "pages": [
                  "billing/invoices",
                  "billing/recurring-billing",
                  "billing/payment-verification"
                ]
              },
              {
                "group": "Activities & Development",
                "hidden": true,
                "pages": [
                  "activities/daily-activities",
                  "activities/lesson-plans",
                  "activities/milestone-tracking",
                  "activities/attendance"
                ]
              },
              {
                "group": "Parent Engagement",
                "hidden": true,
                "pages": [
                  "parents/parent-app",
                  "parents/activity-feed",
                  "parents/invite-family"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Get Free Demo",
      "href": "https://web.fleedu.com/register"
    }
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/fleedu_id"
    }
  },
  "appearance": {
    "default": "light",
    "strict": true
  },
  "logo": {
    "light": "/images/Purple_50x50_rounded.png",
    "dark": "/images/Purple_50x50_rounded.png",
    "href": "https://fleedu.com"
  }
}
